
{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "swr-shell-demo",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-19",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"vars": {
		"BOOTSTRAP_ORIGIN_URL": "https://bootstrap-data-r2-eu.apreswhatever.com/api/bootstrap"
	},
	"observability": {
		"enabled": true,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1
		},
		"traces": {
			"enabled": true,
			"head_sampling_rate": 1
		}
	}
}
