{
	"name": "swr-shell",
	"version": "0.0.0",
	"private": true,
	"packageManager": "pnpm@10.26.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"deploy": "pnpm run build && wrangler deploy",
		"upload:bootstrap-data": "wrangler r2 object put bootstrap-data/api/bootstrap --remote -J eu --file data/bootstrap.json --content-type application/json --cache-control \"public, max-age=30, stale-while-revalidate=2592000\"",
		"test": "vitest --run",
		"typecheck": "tsc --noEmit",
		"cf-typegen": "wrangler types worker-configuration.d.ts --config wrangler.jsonc"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.29.1",
		"@cloudflare/vitest-pool-workers": "^0.12.4",
		"@types/node": "^25.5.0",
		"typescript": "^5.5.2",
		"vite": "^8.0.1",
		"vitest": "~3.2.0",
		"wrangler": "^4.75.0"
	},
	"dependencies": {}
}
