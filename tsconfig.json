{
	"compilerOptions": {
		"target": "es2024",
		"lib": ["es2024"],
		"module": "es2022",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["./worker-configuration.d.ts"]
	},
	"exclude": ["test"],
	"include": ["worker-configuration.d.ts", "src/**/*.ts", "vite.config.mts"]
}
